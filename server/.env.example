# Erythos sync server — environment variables
#
# Production: copy to /opt/erythos/server/.env, fill secrets, chmod 600.
# Local dev:  copy to server/.env in the repo root.

# Node runtime
NODE_ENV=production
PORT=3000

# Postgres connection
# Production example: postgres://erythos:<password>@localhost:5432/erythos
DATABASE_URL=postgres://localhost:5432/erythos

# GitHub OAuth — create at https://github.com/settings/developers
# Authorization callback URL: https://<host>/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Session HMAC secret — generate with: openssl rand -hex 32
SESSION_SECRET=

# Allowed Origin for state-changing API requests (POST/PUT/PATCH/DELETE).
# Comma-separated for multi-origin (e.g. dev preview + local):
#   dev:  http://localhost:5173,http://localhost:4173
#   prod: https://erythos.eoswolf.com
# Defaults to http://localhost:5173 if unset.
ALLOWED_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# DB backup — Linode Object Storage (S3-compatible)
# Used by server/deploy/backup.sh (Phase 13 cron job)
# ---------------------------------------------------------------------------

# Linode Object Storage endpoint (region must match the bucket's region)
# Format: https://<region>.linodeobjects.com   (region-only, NOT https://<bucket>.<region>.linodeobjects.com)
# Tokyo 3 = jp-tyo-1, Singapore = ap-south-1, etc.
S3_ENDPOINT=https://jp-tyo-1.linodeobjects.com

# Backup bucket name (create in Linode dashboard → Object Storage)
S3_BUCKET=erythos-backups

# AWS region for SDK (must match the bucket's region slug above)
AWS_REGION=jp-tyo-1

# Linode Object Storage access key (limited to this bucket)
# Generate in Linode dashboard → Object Storage → Access Keys
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS CLI v2.34+ / boto3 workaround for Linode S3-compatible API.
# Without these, "NoneType is not a container or iterable" on every upload
# (Linode response lacks the checksum header boto3 now expects by default).
AWS_REQUEST_CHECKSUM_CALCULATION=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION=when_required

# scripts/backup.mjs also accepts BACKUP_* aliases below (mapped to the vars above).
# Only set these if you need separate credentials for the Node.js backup script;
# otherwise the AWS_* / S3_* vars above are used automatically.
# BACKUP_S3_ENDPOINT=
# BACKUP_BUCKET=
# BACKUP_S3_REGION=
# BACKUP_S3_KEY=
# BACKUP_S3_SECRET=

# ---------------------------------------------------------------------------
# Metrics basic auth — protect /api/metrics from public access.
# Generate password with: openssl rand -hex 16
# WARNING: set a strong METRICS_PASS before going to production.
#          /api/metrics returns 401 if either var is unset.
# ---------------------------------------------------------------------------
METRICS_USER=metrics
METRICS_PASS=

# ---------------------------------------------------------------------------
# Asset storage — Linode Object Storage (S3-compatible)
# Used by future POST /api/assets endpoints (F-1b/c)
# Bucket separate from S3_BUCKET (backups); endpoint + access key may be shared.
# ---------------------------------------------------------------------------

# Asset bucket name (create in Linode dashboard → Object Storage)
# Recommended: erythos-assets (prod) / erythos-assets-dev (dev)
S3_ASSETS_BUCKET=

# Region — shared with backup if same Linode account (Tokyo 3 = jp-tyo-1)
S3_REGION=jp-tyo-1

# ---------------------------------------------------------------------------
# Magic link auth (F-5 spec docs/magic-link-spec.md § Resend Integration)
# ---------------------------------------------------------------------------

# Resend API key — required for production email delivery (wired in C3).
# When unset (dev / CI / local testing), the /api/auth/magic-link/request
# endpoint logs the plaintext token to server stdout instead of sending email.
# This keeps local sign-in flows usable without a Resend account.
RESEND_API_KEY=

# Sender address. The domain must have SPF / DKIM / DMARC records set up
# at the DNS registrar for deliverability (Resend dashboard provides exact
# record contents). Otherwise emails land in spam.
MAGIC_LINK_FROM_EMAIL=noreply@erythos.eoswolf.com

# Base URL used to construct the verify link embedded in the email.
#   Prod: https://erythos.eoswolf.com    (Caddy reverse-proxies /api → :3000)
#   Dev:  http://localhost:5173          (Vite dev server proxies /api → :3000)
MAGIC_LINK_BASE_URL=http://localhost:5173

# Token TTL in milliseconds (default 900000 = 15 min per spec § Token 規格)
MAGIC_LINK_TTL_MS=900000
