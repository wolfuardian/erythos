#!/bin/bash
# Auto-increment patch version on every commit.
# Only runs on master — feature branches skip to avoid merge conflicts.

branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" != "master" ]; then
  exit 0
fi

if [ -f .version-bumped ]; then
  rm .version-bumped
  exit 0
fi

node scripts/bump.js patch
git add package.json package-lock.json
