#!/bin/bash
# Auto-increment patch version on every commit.
# Only runs on main — feature branches skip to avoid merge conflicts.

branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" != "main" ]; then
  exit 0
fi

if [ -f .version-bumped ]; then
  rm .version-bumped
  exit 0
fi

# Skip bump on .claude/-only commits (meta files, no production code change).
if ! git diff --cached --name-only | grep -qv '^\.claude/'; then
  exit 0
fi

node scripts/bump.js patch
git add package.json package-lock.json
