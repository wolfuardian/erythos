{
  "name": "erythos",
  "private": true,
  "version": "0.1.235",
  "type": "module",
  "description": "A web-based 3D editor built with TypeScript, SolidJS, and Three.js.",
  "author": "Eos Wolfuardian",
  "license": "MIT",
  "homepage": "https://github.com/wolfuardian/erythos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wolfuardian/erythos.git"
  },
  "bugs": {
    "url": "https://github.com/wolfuardian/erythos/issues"
  },
  "keywords": [
    "3d-editor",
    "threejs",
    "solidjs",
    "typescript",
    "vite",
    "webgl"
  ],
  "scripts": {
    "dev": "vite",
    "setup": "node scripts/setup.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "bump:minor": "node scripts/bump.js minor",
    "bump:major": "node scripts/bump.js major",
    "postinstall": "git config core.hooksPath .githooks",
    "audit:scene-tree": "node scripts/audit/scene-tree.mjs",
    "audit:environment": "node scripts/audit/environment.mjs",
    "audit:properties": "node scripts/audit/properties.mjs",
    "audit:viewport": "node scripts/audit/viewport.mjs",
    "audit:leaf": "node scripts/audit/leaf.mjs",
    "audit:project": "node scripts/audit/project.mjs",
    "audit:settings": "node scripts/audit/settings.mjs",
    "audit:context": "node scripts/audit/context.mjs",
    "audit:inline-style": "node scripts/audit/inline-style.mjs",
    "check:command-pattern": "node scripts/check-command-pattern.mjs",
    "check:panel-root": "node scripts/check-panel-root.mjs",
    "check": "npm run check:command-pattern && npm run check:panel-root",
    "lint": "eslint src",
    "server:dev": "npm run -w server dev",
    "server:build": "npm run -w server build"
  },
  "dependencies": {
    "solid-js": "^1.9.12",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^25.6.0",
    "@types/three": "^0.184.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~6.0.3",
    "vite": "^8.0.12",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.1.5"
  },
  "workspaces": [
    "server"
  ]
}
