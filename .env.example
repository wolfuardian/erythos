# Erythos client — Vite environment variables
#
# Copy to .env (gitignored) and customise for local development.
# All VITE_* variables are injected at build time by Vite.

# Sync / auth server base URL.
# Production default: https://erythos.eoswolf.com
# Dev default (when unset): http://localhost:3000
VITE_SYNC_BASE_URL=https://erythos.eoswolf.com
